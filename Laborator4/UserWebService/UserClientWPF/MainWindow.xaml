<Window x:Class="UserClientWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Autentificare utilizator" Height="300" Width="400">
    <StackPanel Margin="20">

        <TextBlock Text="E-mail:"/>
        <TextBox x:Name="EmailTextBox" Height="25" Margin="0,0,0,10"/>

        <TextBlock Text="Parolă:"/>
        <PasswordBox x:Name="PasswordBox" Height="25" Margin="0,0,0,15"/>

        <Button Content="Înregistrare"
                Height="30"
                Margin="0,0,0,10"
                Click="Inregistrare_Click"/>

        <Button Content="Autentificare"
                Height="30"
                Margin="0,0,0,15"
                Click="Autentificare_Click"/>

        <TextBlock x:Name="MesajTextBlock"
                   FontWeight="Bold"
                   TextWrapping="Wrap"/>
    </StackPanel>
</Window>