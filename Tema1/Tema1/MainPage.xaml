<Page
    x:Class="Tema1.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tema1"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="10" ColumnSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Manager de Sarcini"
                   FontSize="25"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Vertical" Spacing="8">
            <TextBlock Text="Titlu sarcina:"/>
            <TextBox x:Name="TitleTextBox"
                     PlaceholderText="Introdu titlul"
                     TextChanged="TitleTextBox_TextChanged"/>

            <TextBlock Text="Descriere:"/>
            <TextBox x:Name="DescriptionTextBox"
                     PlaceholderText="Introdu descrierea"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20">
            <StackPanel>
                <TextBlock Text="Prioritate:"/>
                <ComboBox x:Name="PriorityComboBox" Width="150">
                    <ComboBoxItem Content="Mica"/>
                    <ComboBoxItem Content="Medie"/>
                    <ComboBoxItem Content="Mare"/>
                </ComboBox>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Status:"/>
                <ComboBox x:Name="StatusComboBox" Width="150">
                    <ComboBoxItem Content="De facut"/>
                    <ComboBoxItem Content="In lucru"/>
                    <ComboBoxItem Content="Finalizat"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" Margin="0,10,0,10">
            <Button Content="Adauga" Click="AddButton_Click"/>
            <Button Content="Modifica" Click="EditButton_Click"/>
            <Button Content="Sterge" Click="DeleteButton_Click"/>
            <Button Content="Goleste câmpuri" Click="ClearButton_Click"/>
            <Button Content="Vezi detalii" Click="DetailsButton_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="MessageTextBlock"/>

        <ListView Grid.Row="5"
                  x:Name="TasksListView"
                  SelectionChanged="TasksListView_SelectionChanged"/>
    </Grid>
</Page>