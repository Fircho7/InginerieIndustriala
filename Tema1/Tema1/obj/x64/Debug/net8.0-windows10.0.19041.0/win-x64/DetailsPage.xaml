<Page
    x:Class="Tema1.DetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tema1"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="20" Spacing="10">
        <TextBlock Text="Detalii Sarcină" FontSize="28" FontWeight="Bold"/>
        <TextBlock x:ConnectionId='2' x:Name="TitleBlock"/>
        <TextBlock x:ConnectionId='3' x:Name="DescriptionBlock"/>
        <TextBlock x:ConnectionId='4' x:Name="PriorityBlock"/>
        <TextBlock x:ConnectionId='5' x:Name="StatusBlock"/>
        <Button x:ConnectionId='6' Content="Înapoi"                          Width="120"/>
    </StackPanel>
</Page>

